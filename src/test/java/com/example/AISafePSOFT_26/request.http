### LOGIN (us000-auth)
POST http://localhost:8081/auth/login
Content-Type: application/json

{
  "username": "admin",
  "password": "admin123"
}

> {%
    client.global.set("token", response.body.token);
%}

### US101 - ADD AIRCRAFT MODEL (us101)
POST http://localhost:8081/api/catalog/model
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "modelName": "A320neo",
  "manufacturer": "Airbus",
  "modelImage": [
    "https://upload.wikimedia.org/wikipedia/commons/thumb/4/44/Air_Portugal_A320neo.jpg/320px-Air_Portugal_A320neo.jpg"
  ],
  "specs": {
    "fuelCapacityLiters": 26730,
    "maximumRangeKm": 6300,
    "cruisingSpeedKph": 833,
    "standardSeatingCapacity": 165
  }
}

### US102 - ADD AIRCRAFT (us102)
POST http://localhost:8081/api/hangar/aircraft
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "registrationNumber": "CS-TVA",
  "modelName": "A320neo",
  "manufacturingDate": "2018-03-12",
  "totalOperationalHours": 18450.5,
  "totalFlightHours": 17200.0,
  "availability": "AVAILABLE"
}

### GET AIRCRAFT (us103)
GET http://localhost:8081/api/hangar/aircraft/CS-TVA
Authorization: Bearer {{token}}

### UPDATE AIRCRAFT STATUS (us105)
PATCH http://localhost:8081/api/hangar/aircraft/CS-TVA
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "registrationNumber": "CS-TVA",
  "availability": "MAINTENANCE"
}

### SEARCH AIRCRAFT (us104)
GET http://localhost:8081/api/hangar/aircraft?model=A320neo&status=AVAILABLE
Authorization: Bearer {{token}}

### US106 - REGISTER AIRPORT (us106)
POST http://localhost:8081/api/airports
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "iataCode": "ZCX",
  "airportType": "International",
  "name": "Francisco Sá Carneiro Airport",
  "status": "OPERATIONAL",
  "location": {
    "city": "Porto",
    "longitude": -8.6814,
    "latitude": 41.2481,
    "region": "Norte",
    "timezone": "Europe/Lisbon",
    "country": "Portugal"
  },
  "facilities": {
    "terminalCount": 1,
    "services": ["fuel", "maintenance", "catering", "ground_handling"],
    "gateCount": 36
  },
  "routeDistance": 0.0,
  "runways": [
    {
      "runwayName": "17/35",
      "length": 3480.0,
      "orientation": "N/S",
      "status": "OPEN"
    }
  ],
  "certifications": [],
  "contacts": [
    {
      "type": "EMAIL",
      "value": "ops@opo.pt"
    },
    {
      "type": "PHONE",
      "value": "+351229432400"
    }
  ],
  "airportPhotos": [
    "https://upload.wikimedia.org/wikipedia/commons/thumb/5/5e/Aeroporto_Porto.jpg/320px-Aeroporto_Porto.jpg"
  ]
}

### US107 - GET AIRPORT BY IATA (us107)
GET http://localhost:8081/api/airports/XPT
Authorization: Bearer {{token}}

### US108 - SEARCH AIRPORTS (us108)
GET http://localhost:8081/api/airports?city=Porto&country=Portugal&name=Francisco S%C3%A1 Carneiro Airport
Authorization: Bearer {{token}}

### US106A - ADD CERTIFICATION (us106a)
POST http://localhost:8081/api/airports/OPO/certifications
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "name": "EASA Aerodrome Certificate",
  "category": "SAFETY",
  "startsAt": "2024-01-01",
  "expiresAt": "2027-01-01"
}

### US109 - UPDATE AIRPORT STATUS (us109)
PATCH http://localhost:8081/api/airports/OPO/status
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "status": "UNDER_MAINTENANCE"
}

