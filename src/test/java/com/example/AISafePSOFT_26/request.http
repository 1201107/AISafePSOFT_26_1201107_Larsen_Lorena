### US207 - REGISTER ENHANCED AIRPORT with OPERATIONAL HOURS (us207)
POST http://localhost:8081/api/airports
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "iataCode": "LIS",
  "airportType": "International",
  "name": "Humberto Delgado Airport",
  "status": "OPERATIONAL",
  "operationalHours": "06:00-23:00",
  "location": {
    "city": "Lisbon",
    "longitude": -9.1359,
    "latitude": 38.7742,
    "region": "Lisbon",
    "timezone": "Europe/Lisbon",
    "country": "Portugal"
  },
  "facilities": {
    "terminalCount": 2,
    "services": ["fuel", "maintenance"],
    "gateCount": 48
  },
  "routeDistance": 0.0,
  "runways": [
    {
      "runwayName": "03/21",
      "length": 3805.0,
