@startuml
skinparam monochrome true
skinparam shadowing false

title Diagrama de Sequência: US112 - Atualizar ou Desativar Rota

actor "ATCC / Backoffice" as User
participant ":ControladorAutenticacao" as Auth
participant ":ControladorRota" as Ctrl
participant ":ServicoRota" as Service
participant ":RepositorioRota" as RepoRoute
participant "rota:Rota" as Route <<Raiz do Agregado>>

activate User

User -> Auth : Autenticar Utilizador
activate Auth
Auth --> User : Autenticação Bem-sucedida (Token JWT)
deactivate Auth

User -> Ctrl : atualizarRota(routeId, dadosAtualizacao)
activate Ctrl

Ctrl -> Service : atualizarRota(routeId, dadosAtualizacao)
activate Service

    Service -> RepoRoute : procurarPorId(routeId)
    activate RepoRoute
    RepoRoute --> Service : rota
    deactivate RepoRoute

    Service -> Route : atualizarOuDesativar(dadosAtualizacao)
    activate Route
    Route --> Service
    deactivate Route

    Service -> RepoRoute : guardar(rota)
    activate RepoRoute
    note over RepoRoute : Controlo de concorrência\n(Bloqueio Otimista)
    RepoRoute --> Service : rotaGuardada
    deactivate RepoRoute

    Service --> Ctrl : rotaDTO / Erro

    Ctrl --> User : Sucesso (200 OK)

    Ctrl --> User : Erro (404 Não Encontrado / 400 Pedido Inválido)

    Ctrl --> User : Erro (409 Conflito - Falha de Concorrência)

deactivate Service
deactivate Ctrl
deactivate User
@enduml