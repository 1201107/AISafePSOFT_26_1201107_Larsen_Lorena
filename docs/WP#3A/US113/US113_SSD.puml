@startuml
skinparam monochrome true
skinparam shadowing false

title System Sequence Diagram (SSD) - US113

actor "ATCC" as User
participant "System" as System

activate User


User -> System : Authenticate User
activate System
System --> User : Authentication Successful (Token JWT)
deactivate System


User -> System : getRoutesFromAirport(airportIATA)
activate System

System --> User : Inform Success (200 OK + Routes List)

System --> User : Error (404 Not Found)
deactivate System


User -> System : getRouteDetails(routeId)
activate System

System --> User : Inform Success (200 OK + Route Details)

System --> User : Error (404 Not Found)
deactivate System

deactivate User
@enduml