@startuml
skinparam monochrome true
skinparam shadowing false

title Diagrama de Sequência do Sistema (SSD) - US114

actor "ATCC" as User
participant "Sistema" as System

activate User

User -> System : Autenticar Utilizador
activate System
System --> User : Autenticação Bem-sucedida (Token JWT)
deactivate System

User -> System : pesquisarRotas(origem, destino)
activate System

System --> User : Informar Sucesso (200 OK + Lista de Rotas Filtradas)
System --> User : Erro (400 Pedido Inválido)

deactivate System
deactivate User
@enduml