@startuml

actor "Backoffice Operator" as BO

participant "ModelCatalogController" as CC
participant "AddModelUseCase" as AMC
participant "AircraftModel" as AM
participant "AircraftModelRepository" as AMR

BO -> CC : POST /aircraft-models\n{ modelName, manufacturer,\n aircraftModelSpecs, modelImage }
activate CC

CC -> CC : extract collaboratorId from JWT

CC -> AMC : execute(model)
activate AMC

AMC -> AMR : save(model)
activate AMR

AMR --> AMC : persisted(model)
deactivate AMR

AMC --> CC : model saved
deactivate AMC

CC --> BO : 201 CREATED
deactivate CC

@enduml