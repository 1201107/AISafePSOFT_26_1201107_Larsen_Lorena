@startuml
skinparam classAttributeIconSize 0
hide empty members
skinparam packageStyle frame

' AIRPORT AGGREGATE
package "Aggregate: Airport" <<Frame>> {
    class Airport <<aggregate root>> {
        - iataCode: String <<id>>
        - name: String
        - status: AirportStatus
        - region: String
        + updateStatus(status: AirportStatus)
    }

    class AirportLocation <<value object>> {
        - city: String
        - country: String
        - timezone: String
        - latitude: Double
        - longitude: Double
    }

    class Facilities <<value object>> {
        - terminalCount: Integer
        - gateCount: Integer
        - services: List<String>
    }

    class Contact <<value object>> {
        - type: ContactType
        - value: String
        - description: String
    }

    enum AirportStatus {
        OPERATIONAL
        CLOSED
    }

    enum ContactType {
        PHONE
        EMAIL
        FAX
    }

    Airport "1"--"1" AirportLocation
    Airport *-- Facilities
    Airport *-- "0..*" Contact : "multiples contacts per airport"
}

' ROUTE AGGREGATE
package "Aggregate: Route" <<Frame>> {
    class Route <<aggregate root>> {
        - routeId: String <<id>>
        - status: RouteStatus
        - originIataCode: String <<ref>>
        - destinationIataCode: String <<ref>>
        - distance: Double
        - estimatedFlightTime: Double
    }

    interface SearchStrategy <<interface>> {
        + findPath(origin, destination)
    }

    class RouteRequirements <<value object>> {
        - requiredRange: Double
        - requiredCapacity: Integer
    }

    enum RouteStatus {
        ACTIVE
        INACTIVE
    }

    Route *-- RouteRequirements
    Route ..> SearchStrategy : "strategy for US216"
}

' AIRCRAFT AGGREGATE (CONSOLIDATED)
package "Aggregate: Aircraft" <<Frame>> {
    class Aircraft <<aggregate root>> {
        - registrationNumber: String <<id>>
        - modelId: String <<ref>>
        - manufacturingDate: Date
        - status: AircraftAvailability
        - seatingCapacity: Integer
        - features: List<String>
        - totalOperationalHours: Double
        + updateStatus(status: AircraftAvailability)
    }

    class AircraftModel <<entity>> {
        - modelId: String <<id>>
        - manufacturer: String
        - modelName: String
        - baseSpecs: AircraftSpecs
    }

    class AircraftSpecs <<value object>> {
        - fuelCapacity: Double
        - maximumRange: Double
        - cruisingSpeed: Double
    }

    enum AircraftAvailability {
        AVAILABLE
        ASSIGNED
        IN_FLIGHT
        MAINTENANCE
        INACTIVE
    }

    Aircraft --> AircraftModel : "linked to model [cite: 32, 33]"
    AircraftModel *-- AircraftSpecs
}

' FLIGHT AGGREGATE
package "Aggregate: Flight" <<Frame>> {
    class ScheduledFlight <<aggregate root>> {
        - flightId: String <<id>>
        - status: FlightStatus
        - routeId: String <<ref>>
        - aircraftId: String <<ref>>
        - scheduledDeparture: DateTime
        - scheduledArrival: DateTime
    }

    enum FlightStatus {
        SCHEDULED
        DELAYED
        IN_FLIGHT
        COMPLETED
        CANCELED
    }

    ScheduledFlight --> Route : "ref [cite: 102]"
    ScheduledFlight --> Aircraft : "ref [cite: 102]"
}

' MAINTENANCE AGGREGATE
package "Aggregate: Maintenance" <<Frame>> {
    class MaintenanceRecord <<aggregate root>> {
        - recordId: String <<id>>
        - aircraftId: String <<ref>>
        - templateId: String <<ref>>
        - startDate: Date
        - status: MaintenanceStatus
    }

    class MaintenanceTemplate <<entity>> {
        - templateId: String <<id>>
        - name: String
        - checklist: String
        - flightHourInterval: Double
        - calendarDayInterval: Integer
        - operation: MaintenanceOperation
    }

    class MaintenancePart <<entity>> {
        - partNumber: String <<id>>
        - name: String
        - stockQuantity: Integer
        - description: String
    }

    enum MaintenanceStatus {
        ONGOING
        COMPLETED
    }

    MaintenanceRecord *-- "1" MaintenanceTemplate
    MaintenanceRecord --> Aircraft : "ref [cite: 57]"
}

@enduml