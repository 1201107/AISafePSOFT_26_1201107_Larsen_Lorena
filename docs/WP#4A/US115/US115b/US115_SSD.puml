@startuml
skinparam monochrome true
skinparam shadowing false

title Diagrama de Sequência do Sistema (SSD) - US115

actor "Técnico de Manutenção" as User
participant "Sistema" as System

activate User

User -> System : Autenticar Utilizador
activate System
System --> User : Autenticação Bem-sucedida (Token JWT)
deactivate System

User -> System : criarModeloManutencao(nome, tipo, modelosAeronave, checklist)
activate System

System --> User : Informar Sucesso (201 Criado + Dados do Modelo)
System --> User : Erro (400 Pedido Inválido)

deactivate System
deactivate User
@enduml